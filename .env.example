# AI邮件教练环境变量配置示例
# 复制此文件为 .env 并填入真实的配置信息

# ============================================
# Supabase 数据库配置（必需）
# ============================================
# 获取方式：
# 1. 访问 https://supabase.com 并登录
# 2. 创建新项目或选择现有项目
# 3. 进入 Settings → API
# 4. 复制 Project URL 和 service_role key（注意：使用 service_role key，不是 anon key）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ============================================
# DeepSeek AI 配置（必需）
# ============================================
# 获取方式：
# 1. 访问 https://platform.deepseek.com 并注册
# 2. 进入 API Keys 页面
# 3. 创建新的 API Key
# 用途：用于智能解析邮件回复内容
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ============================================
# 163 邮箱配置（必需）
# ============================================
# 获取方式：
# 1. 登录 163 邮箱网页版
# 2. 设置 → POP3/SMTP/IMAP
# 3. 开启 SMTP 服务
# 4. 获取授权码（不是邮箱密码）
# 用途：用于发送每日复盘邮件和接收用户回复
EMAIL_163_USERNAME=your-email@163.com
EMAIL_163_PASSWORD=your-163-authorization-code

# ============================================
# 飞书机器人配置（可选）
# ============================================
# 获取方式：
# 1. 在飞书群中添加自定义机器人
# 2. 获取 Webhook URL
# 用途：用于发送通知到飞书群（如果不使用飞书，可以留空或删除此行）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url

# ============================================
# 应用配置（可选）
# ============================================
# DEBUG: 是否开启调试模式（True/False）
# LOG_LEVEL: 日志级别（DEBUG/INFO/WARNING/ERROR）
DEBUG=True
LOG_LEVEL=INFO

# ============================================
# Resend 邮件服务配置（暂未使用，保留供未来扩展）
# ============================================
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_WEBHOOK_SECRET=your-webhook-secret